<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.ShoshinAPP" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>

    <!-- Night theme -->
    <style name="Theme.ShoshinAPP.Night" parent="Theme.ShoshinAPP">
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Android 12+ Splash Screen style -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/sh_ink</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.ShoshinAPP</item>
    </style>
</resources>
